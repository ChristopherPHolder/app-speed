{
  "name": "portal-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/portal/src",
  "tags": [
    "frontend"
  ],
  "targets": {
    "build": {
      "executor": "@nx/angular:application",
      "outputs": [
        "{options.outputPath.base}"
      ],
      "options": {
        "outputPath": {
          "base": "dist/{projectRoot}",
          "browser": ""
        },
        "index": "{projectRoot}/src/index.html",
        "polyfills": [
          "zone.js"
        ],
        "tsConfig": "{projectRoot}/tsconfig.app.json",
        "assets": [
          "{projectRoot}/src/favicon.ico",
          "{projectRoot}/src/assets"
        ],
        "styles": [
          "{workspaceRoot}/libs/portal/ui/theme/styles.scss"
        ],
        "browser": "{projectRoot}/src/main.ts"
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "477kb",
              "maximumError": "500kb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "5kb",
              "maximumError": "7kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@nx/angular:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "portal-app:build:production"
        },
        "development": {
          "buildTarget": "portal-app:build:development"
        }
      },
      "defaultConfiguration": "development",
      "continuous": true
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n",
      "options": {
        "buildTarget": "portal-app:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ]
    },
    "test": {
      "executor": "@nx/angular:unit-test",
      "options": {
        "tsConfig": "apps/portal/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "portal-app:build"
      }
    },
    "deploy": {
      "executor": "@app-speed/aws-deploy:s3-upload",
      "dependsOn": [
        "build"
      ],
      "options": {
        "upload": "dist/{projectRoot}"
      },
      "configurations": {
        "production": {
          "bucket": "s3://appspeed.dev"
        },
        "development": {
          "bucket": "s3://dev.appspeed.dev"
        }
      },
      "defaultConfiguration": "development"
    }
  }
}
