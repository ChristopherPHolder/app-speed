{
  "name": "runner-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "apps/runner",
  "sourceRoot": "apps/runner/src",
  "projectType": "application",
  "tags": ["backend"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "platform": "node",
        "outputPath": "dist/{projectRoot}",
        "format": ["esm"],
        "bundle": true,
        "main": "{projectRoot}/src/bin.ts",
        "tsConfig": "{projectRoot}/tsconfig.app.json",
        "assets": ["{projectRoot}/src/assets"],
        "generatePackageJson": true,
        "esbuildOptions": {
          "sourcemap": true,
          "outExtension": {
            ".js": ".js"
          }
        }
      },
      "configurations": {
        "development": {},
        "production": {
          "esbuildOptions": {
            "sourcemap": false
          }
        }
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "runner-app:build"
      },
      "configurations": {
        "development": {
          "buildTarget": "runner-app:build:development"
        },
        "production": {
          "buildTarget": "runner-app:build:production"
        }
      }
    },
    "execute": {
      "command": "node dist/{projectRoot}",
      "dependsOn": ["build"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "s3-upload": {
      "executor": "@app-speed/aws-deploy:s3-upload",
      "dependsOn": ["build"],
      "options": {
        "upload": "dist/{projectRoot}",
        "bucket": "s3://ufo-runner-dev"
      }
    },
    "deploy": {
      "executor": "@app-speed/aws-deploy:ec2-ssm-cycle",
      "defaultConfiguration": "development",
      "options": {
        "region": "eu-central-1",
        "instanceId": "i-049287bf43503d01e",
        "documentName": "AWS-RunShellScript",
        "containerName": "app-speed-runner",
        "stopAfterCompletion": true,
        "stopOnlyIfStarted": true,
        "pollIntervalMs": 5000,
        "timeoutMs": 900000
      },
      "configurations": {
        "development": {
          "additionalRunArgs": [
            "-e RUNNER_API_BASE_URL=https://dev.appspeed.dev/api",
            "-e RUNNER_HEADLESS=true"
          ]
        },
        "production": {
          "additionalRunArgs": [
            "-e RUNNER_API_BASE_URL=https://appspeed.dev/api",
            "-e RUNNER_HEADLESS=true"
          ]
        }
      }
    }
  }
}
