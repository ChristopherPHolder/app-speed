{
  "name": "platform-observability",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/platform/observability/src",
  "projectType": "library",
  "tags": ["type:platform", "scope:shared", "runtime:node"],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "platform": "node",
        "outputPath": "dist/{projectRoot}",
        "format": ["esm"],
        "bundle": true,
        "main": "{projectRoot}/src/public-api.ts",
        "tsConfig": "{projectRoot}/tsconfig.lib.json",
        "assets": ["{projectRoot}/*.md"],
        "esbuildOptions": {
          "sourcemap": true,
          "outExtension": {
            ".js": ".js"
          }
        }
      },
      "configurations": {
        "production": {
          "esbuildOptions": {
            "sourcemap": false,
            "outExtension": {
              ".js": ".js"
            }
          }
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "effect:diagnostics": {
      "executor": "@app-speed/effect-tools:diagnostics",
      "options": {
        "tsConfig": "{projectRoot}/tsconfig.lib.json",
        "format": "text",
        "severity": "error,warning,message"
      }
    }
  }
}
