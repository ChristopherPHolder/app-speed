{
  "name": "portal-ui",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/portal/ui",
  "prefix": "ui",
  "tags": ["type:foundation", "scope:shared", "runtime:browser", "layer:ui"],
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "{workspaceRoot}/{projectRoot}/ng-package.json",
        "tsConfig": "{workspaceRoot}/{projectRoot}/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "{workspaceRoot}/{projectRoot}/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "configFile": "{projectRoot}/vitest.config.mts",
        "reportsDirectory": "../../../coverage/libs/portal/ui",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    }
  }
}
