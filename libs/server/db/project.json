{
  "name": "db",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/server/db/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/server/db",
        "main": "libs/server/db/src/index.ts",
        "tsConfig": "libs/server/db/tsconfig.lib.json",
        "assets": ["libs/server/db/*.md"],
        "format": ["esm"],
        "generatePackageJson": true
      }
    },
    "prisma-generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx prisma generate --config libs/server/db/prisma.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "prisma-migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx prisma migrate dev --config libs/server/db/prisma.config.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "prisma-studio": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx prisma studio --config libs/server/db/prisma.config.ts",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
