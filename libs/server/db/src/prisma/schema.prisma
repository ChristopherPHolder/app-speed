generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum AuditStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETE
}

enum AuditResultStatus {
  SUCCESS
  FAILURE
}

model AuditTemplate {
  id        String     @id @unique @default(uuid())
  data      Json
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  runs      AuditRun[]
}

model AuditRun {
  id          String        @id @unique @default(uuid())
  templateId  String
  template    AuditTemplate @relation(fields: [templateId], references: [id])
  status      AuditStatus   @default(SCHEDULED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  startedAt   DateTime?
  completedAt DateTime?
  durationMs  Int?
  result      AuditResult?
}

model AuditResult {
  id        String            @id @default(uuid())
  runId     String            @unique
  run       AuditRun          @relation(fields: [runId], references: [id])
  status    AuditResultStatus
  data      Json?
  error     Json?
  createdAt DateTime          @default(now())
}
