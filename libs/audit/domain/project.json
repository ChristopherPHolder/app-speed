{
  "name": "audit-domain",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/audit/domain/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": ["type:domain", "scope:audit", "runtime:agnostic", "layer:model"],
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "libs/audit/domain/ng-package.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/audit/domain/tsconfig.lib.prod.json"
        },
        "development": {
          "tsConfig": "libs/audit/domain/tsconfig.lib.json"
        }
      },
      "defaultConfiguration": "production"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "effect:diagnostics": {
      "executor": "@app-speed/effect-tools:diagnostics",
      "options": {
        "tsConfig": "{projectRoot}/tsconfig.lib.json",
        "format": "text",
        "severity": "error,warning,message"
      }
    }
  }
}
