{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "types": [],
    "moduleResolution": "bundler"
  },
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.stories.ts",
    "src/**/*.stories.js",
    "runs/src/**/*.spec.ts",
    "runs/src/**/*.test.ts",
    "runs/src/**/*.stories.ts",
    "runs/src/**/*.stories.js"
  ],
  "include": ["src/**/*.ts", "runs/src/**/*.ts"]
}
