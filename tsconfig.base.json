{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "baseUrl": ".",
    "rootDir": ".",
    "paths": {
      "@app-speed/aws-deploy": ["tools/aws-deploy/src/index.ts"],
      "@app-speed/db-tools": ["tools/db-tools/src/index.ts"],
      "@app-speed/effect-tools": ["tools/effect-tools/src/index.ts"],
      "@app-speed/audit/portal/builder": ["libs/audit/portal/builder/src/index.ts"],
      "@app-speed/audit/portal/runs": ["libs/audit/portal/runs/src/index.ts"],
      "@app-speed/audit/portal/viewer": ["libs/audit/portal/viewer/src/index.ts"],
      "@app-speed/ui": ["libs/ui/src/public-api.ts"],
      "@app-speed/ui/scroll-container": ["libs/ui/scroll-container/public-api.ts"],
      "@app-speed/ui/status-badge": ["libs/ui/status-badge/public-api.ts"],
      "@app-speed/audit/runner": ["libs/audit/runner/src/public-api.ts"],
      "@app-speed/audit/api-runtime": ["libs/audit/api-runtime/src/index.ts"],
      "@app-speed/platform/observability": ["libs/platform/observability/src/public-api.ts"],
      "@app-speed/audit/api-contract": ["libs/audit/api-contract/src/index.ts"],
      "@app-speed/audit/persistence": ["libs/audit/persistence/src/index.ts"],
      "@app-speed/audit/portal/ui": ["libs/audit/portal/ui/src/index.ts"],
      "@app-speed/audit/portal/ui/icons": ["libs/audit/portal/ui/icons/src/index.ts"],
      "@app-speed/audit/portal/ui/dialogs": ["libs/audit/portal/ui/dialogs/src/index.ts"],
      "@app-speed/audit/portal/ui/form-fields": ["libs/audit/portal/ui/form-fields/src/index.ts"],
      "@app-speed/audit/portal/data-access": ["libs/audit/portal/data-access/src/index.ts"],
      "@app-speed/audit/domain": ["libs/audit/domain/src/index.ts"],
      "@app-speed/audit/portal/model": ["libs/audit/portal/model/src/index.ts"]
    },
    "plugins": [
      {
        "name": "@effect/language-service"
      }
    ]
  }
}
