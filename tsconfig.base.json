{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "baseUrl": ".",
    "rootDir": ".",
    "paths": {
      "@app-speed/aws-deploy": ["tools/aws-deploy/src/index.ts"],
      "@app-speed/db-tools": ["tools/db-tools/src/index.ts"],
      "@app-speed/effect-tools": ["tools/effect-tools/src/index.ts"],
      "@app-speed/portal-data-access": ["libs/portal/data-access/src/index.ts"],
      "@app-speed/portal-feature-audit": ["libs/portal/feature-audit/src/index.ts"],
      "@app-speed/portal-feature-shell": ["libs/portal/feature-shell/src/index.ts"],
      "@app-speed/portal-ui-audit-builder": ["libs/portal/ui-audit-builder/src/index.ts"],
      "@app-speed/portal-ui/audit-builder": ["libs/portal/ui/audit-builder/src/index.ts"],
      "@app-speed/portal-ui/audit-summary": ["libs/portal/ui/audit-summary/src/index.ts"],
      "@app-speed/portal-ui/fractional-result-chip": ["libs/portal/ui/fractional-result-chip/public-api.ts"],
      "@app-speed/portal-ui/loading-spinner": ["libs/portal/ui/loading-spinner/public-api.ts"],
      "@app-speed/portal-ui/radial-chart": ["libs/portal/ui/radial-chart/public-api.ts"],
      "@app-speed/portal-ui/scroll-container": ["libs/portal/ui/scroll-container/public-api.ts"],
      "@app-speed/portal-ui/status-badge": ["libs/portal/ui/status-badge/public-api.ts"],
      "@app-speed/runner-user-flow-replay": ["libs/runner/user-flow-replay/src/public-api.ts"],
      "@app-speed/shared-observability": ["libs/shared/observability/src/public-api.ts"],
      "@app-speed/shared-environments": ["libs/shared/environments/src/public-api.ts"],
      "@app-speed/shared-user-flow-replay": ["libs/shared/user-flow-replay/src/index.ts"],
      "@app-speed/shared-user-flow-replay/schema": ["libs/shared/user-flow-replay/schema/src/index.ts"],
      "@app-speed/shared-utils": ["libs/shared/utils/src/public-api.ts"],
      "@app-speed/userflow-conductor/shared-util-lib": ["packages/userflow-conductor/shared-util-lib/src/index.ts"],
      "@app-speed/userflow-conductor/socket-io-ser": ["packages/userflow-conductor/socket-io-ser/src/index.ts"],
      "@app-speed/server/db": ["libs/server/db/src/index.ts"]
    },
    "plugins": [
      {
        "name": "@effect/language-service"
      }
    ]
  }
}
