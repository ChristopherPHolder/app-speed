{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "baseUrl": ".",
    "rootDir": ".",
    "paths": {
      "@app-speed/aws-deploy": ["tools/aws-deploy/src/index.ts"],
      "@app-speed/db-tools": ["tools/db-tools/src/index.ts"],
      "@app-speed/effect-tools": ["tools/effect-tools/src/index.ts"],
      "@app-speed/audit/portal-data-access": ["libs/audit/portal/data-access/src/index.ts"],
      "@app-speed/audit/portal-data-access-runs": ["libs/audit/portal/data-access-runs/src/index.ts"],
      "@app-speed/audit/portal-feature": ["libs/audit/portal/feature/src/index.ts"],
      "@app-speed/audit/portal-feature-runs": ["libs/audit/portal/feature-runs/src/index.ts"],
      "@app-speed/portal-feature-shell": ["libs/portal/feature-shell/src/index.ts"],
      "@app-speed/audit/portal-ui-runs": ["libs/audit/portal/ui-runs/src/index.ts"],
      "@app-speed/audit/portal-ui-builder": ["libs/audit/portal/ui-builder/src/index.ts"],
      "@app-speed/audit/portal-ui-summary": ["libs/audit/portal/ui-summary/src/index.ts"],
      "@app-speed/portal-ui/fractional-result-chip": ["libs/portal/ui/fractional-result-chip/public-api.ts"],
      "@app-speed/portal-ui/radial-chart": ["libs/portal/ui/radial-chart/public-api.ts"],
      "@app-speed/portal-ui/scroll-container": ["libs/portal/ui/scroll-container/public-api.ts"],
      "@app-speed/portal-ui/status-badge": ["libs/portal/ui/status-badge/public-api.ts"],
      "@app-speed/audit/portal-ui-diagnostics": ["libs/audit/portal/ui-diagnostics/src/index.ts"],
      "@app-speed/audit/runner": ["libs/audit/runner/src/public-api.ts"],
      "@app-speed/audit/control-plane": ["libs/audit/control-plane/src/index.ts"],
      "@app-speed/platform/observability": ["libs/platform/observability/src/public-api.ts"],
      "@app-speed/audit/model": ["libs/audit/model/src/index.ts"],
      "@app-speed/audit/contracts": ["libs/audit/contracts/src/index.ts"],
      "@app-speed/audit/persistence": ["libs/audit/persistence/src/index.ts"]
    },
    "plugins": [
      {
        "name": "@effect/language-service"
      }
    ]
  }
}
